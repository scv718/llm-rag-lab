GEMINI_API_KEY=your_gemini_api_key

# API endpoints used by the Streamlit UI
UPLOAD_API_URL=http://127.0.0.1:8000/upload
RAG_API_URL=http://127.0.0.1:8000/rag/ask

# Optional runtime overrides
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LOCAL_LLM_MODEL=qwen2.5-coder:7b

# Retrieval defaults and caps
RETRIEVAL_LIMIT=30
SEARCH_RERANK_LIMIT=12

# Optional OpenAI-compatible settings
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=your_openai_api_key
